rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isConnectedPair(members) {
      return signedIn() && members.size() == 2 && members.hasAny([request.auth.uid])
          && myProfile().data.partnerId in members;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId ||
        (resource.data.partnerId == '' && request.resource.data.partnerId == request.auth.uid &&
         getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == userId));
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isConnectedPair(resource.data.members);
      allow create: if isConnectedPair(request.resource.data.members)
          && request.resource.data.members[0] < request.resource.data.members[1];
      allow update: if isConnectedPair(resource.data.members)
          && request.resource.data.members == resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt']);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConnectedPair(get(/databases/$(database)/documents/chats/$(chatId)).data.members);
        allow create: if isConnectedPair(getAfter(/databases/$(database)/documents/chats/$(chatId)).data.members)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.diff({}).affectedKeys().hasOnly(['senderId', 'text', 'sentAt', 'seen']);
        allow update: if isConnectedPair(get(/databases/$(database)/documents/chats/$(chatId)).data.members)
          && resource.data.senderId != request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seen'])
          && request.resource.data.seen == true;
        allow delete: if false;
      }
    }
  }
}
